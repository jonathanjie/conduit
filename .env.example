# Conduit — Environment Variables
# Copy to .env and fill in values. NEVER commit .env to version control.

# === Bot ===
BOT_TOKEN=
BOT_USERNAME=             # e.g. MathMavens_bot (without @)
TELEGRAM_WEBHOOK_SECRET=
ADMIN_CHAT_ID=

# === Database ===
DATABASE_URL=postgres://conduit:conduit@localhost:5432/conduit
APP_ENCRYPTION_KEY=  # 32-byte hex string for AES-256

# === Redis ===
REDIS_URL=redis://localhost:6379

# === Server ===
NODE_ENV=development
PORT=3000

# === Dashboard Auth ===
DASHBOARD_SESSION_SECRET=  # Random 64-char hex string
BCRYPT_COST_FACTOR=12

# === Webhook (production only) ===
WEBHOOK_URL=  # e.g. https://conduit.example.com/webhook
