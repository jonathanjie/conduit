{
  "name": "conduit",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ --ext .ts",
    "typecheck": "tsc --noEmit",
    "migrate": "node-pg-migrate up --migration-file-language sql --migrations-dir src/db/migrations",
    "migrate:down": "node-pg-migrate down --migration-file-language sql --migrations-dir src/db/migrations",
    "seed": "tsx src/db/seed.ts",
    "frontend:dev": "cd frontend && npm run dev",
    "frontend:build": "cd frontend && npm run build"
  },
  "dependencies": {
    "grammy": "^1.35.0",
    "@grammyjs/conversations": "^2.0.3",
    "@grammyjs/storage-redis": "^2.4.2",
    "hono": "^4.6.0",
    "@hono/node-server": "^1.13.0",
    "pg": "^8.13.0",
    "node-pg-migrate": "^7.9.0",
    "ioredis": "^5.4.0",
    "bullmq": "^5.31.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "zod": "^3.24.0",
    "bcrypt": "^5.1.1",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "tsx": "^4.19.0",
    "tsc-alias": "^1.8.10",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.0",
    "@types/bcrypt": "^5.0.2",
    "vitest": "^3.0.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.0"
  }
}
